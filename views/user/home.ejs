<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/userStyle.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="profile-section">
                <div class="profile-img">
                    <% if (user.profileImage) { %>
                        <img src="<%= user.profileImage %>" alt="Profile" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">
                    <% } else { %>
                        <i class="fa-solid fa-user"></i>
                    <% } %>
                </div>
                <h2><%= user.username %></h2>
                <p><%= user.email %></p>
            </div>
            <div class="sidebar-menu">
                <a href="/logout" class="logout-btn"><i class="fa-solid fa-sign-out-alt"></i> Logout</a>
            </div>
        </aside>

        <main class="main-content">
            <div id="dashboardHome">
                <h1 class="dashboard-title">Welcome, <%= user.username %>!</h1>
                <div class="games-container">
                    <div class="game-card" onclick="openGame('wordSearch')">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <h3>Word Search</h3>
                        <p>Find the hidden technical words!</p>
                    </div>
                    <div class="game-card" onclick="openGame('crossword')">
                        <i class="fa-solid fa-table-cells"></i>
                        <h3>Crossword</h3>
                        <p>Test your knowledge with crosswords!</p>
                    </div>
                </div>
            </div>

            <!-- Word Search Area -->
            <div id="wordSearchArea" class="game-area" style="display: none;">
                <button class="back-btn" onclick="closeGame()"><i class="fa-solid fa-arrow-left"></i> Back</button>
                <h2>Word Search</h2>
                <p style="margin-bottom: 20px; color: #b5e1ef;">Drag to select words. They can be horizontal, vertical, or diagonal (forwards or backwards).</p>
                <div class="word-search-container">
                    <div id="wsGrid" class="ws-grid"></div>
                    <div class="ws-words">
                        <h3>Words to find:</h3>
                        <ul id="wsWordList"></ul>
                        <button class="action-btn" onclick="initWordSearch()">Restart Game</button>
                    </div>
                </div>
            </div>

            <!-- Crossword Area -->
            <div id="crosswordArea" class="game-area" style="display: none;">
                <button class="back-btn" onclick="closeGame()"><i class="fa-solid fa-arrow-left"></i> Back</button>
                <h2>Crossword</h2>
                <p style="margin-bottom: 20px; color: #b5e1ef;">Click a cell and type. Navigation is constrained to the active word direction.</p>
                <div class="crossword-container">
                    <div class="cw-grid-wrapper">
                        <div id="cwGrid" class="cw-grid"></div>
                    </div>
                    <div class="cw-clues">
                        <div class="clues-across">
                            <h3>Across</h3>
                            <ul id="cwAcrossClues"></ul>
                        </div>
                        <div class="clues-down">
                            <h3>Down</h3>
                            <ul id="cwDownClues"></ul>
                        </div>
                        <button class="action-btn" onclick="initCrossword()" style="margin-top: 20px;">Restart Game</button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const userData = <%- userJson %>;
    </script>
    <script src="/js/dashboard.js"></script>
</body>
</html>
